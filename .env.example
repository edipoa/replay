# ── Required ──────────────────────────────────────────────────────────────────
REPLAY_RTSP_URL=rtsp://192.168.1.100:554/live
REPLAY_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPQRstUvWxYz
REPLAY_CHAT_ID=-1001234567890

# ── Optional (defaults shown) ─────────────────────────────────────────────────
REPLAY_GPIO_PIN=GPIO17
REPLAY_DEBOUNCE_MS=2000
REPLAY_BUFFER_DIR=/tmp/replay_buffer
REPLAY_OUTPUT_DIR=/tmp/replays
REPLAY_AGENDA_PATH=/etc/replay/agenda.json
REPLAY_SEGMENT_TIME_S=2
